---
import { site } from '../data/config';
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border)] mt-20" role="contentinfo">
  <div class="max-w-6xl mx-auto px-5 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 mb-10">
      <div>
        <p class="text-xl text-[var(--accent)] mb-2" style="font-family: Georgia, serif;">Lucid</p>
        <p class="text-sm text-[var(--text-tertiary)] max-w-[180px]">{site.tagline}</p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-3" style="font-family: inherit;">Product</h3>
        <ul class="space-y-2">
          <li><a href="/#exercises" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Exercises</a></li>
          <li><a href="/#pricing" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Pricing</a></li>
          <li><a href={site.appStoreUrl} target="_blank" rel="noopener" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">App Store</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-3" style="font-family: inherit;">Company</h3>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Privacy</a></li>
          <li><a href="/terms" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Terms</a></li>
          <li><a href="/support" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Support</a></li>
          <li><a href={`mailto:${site.supportEmail}`} class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">{site.supportEmail}</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-6 border-t border-[var(--border)] flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-[var(--text-tertiary)]">&copy; {year} {site.company}. All rights reserved.</p>
      <p class="text-xs text-[var(--text-tertiary)]">Apple and the Apple logo are trademarks of Apple Inc.</p>
    </div>
  </div>
</footer>
