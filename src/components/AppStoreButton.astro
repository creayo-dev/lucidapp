---
import { site } from '../data/config';

interface Props {
  class?: string;
  size?: 'default' | 'small';
}

const { class: className = '', size = 'default' } = Astro.props;
const width = size === 'small' ? 120 : 150;
const height = size === 'small' ? 40 : 50;
---

<a
  href={site.appStoreUrl}
  target="_blank"
  rel="noopener"
  class:list={['inline-block', className]}
  aria-label="Download Lucid on the App Store"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 40" width={width} height={height} role="img" aria-hidden="true">
    <title>Download on the App Store</title>
    <rect width="120" height="40" rx="6" fill="#000" />
    <rect x="0.5" y="0.5" width="119" height="39" rx="5.5" stroke="#A6A6A6" stroke-width="1" fill="none" />
    <g fill="#fff">
      <path d="M24.77 20.3a4.95 4.95 0 012.35-4.15 5.07 5.07 0 00-3.99-2.15c-1.67-.18-3.3 1-4.15 1s-2.19-.99-3.61-.96a5.32 5.32 0 00-4.48 2.73c-1.93 3.34-.49 8.27 1.36 10.97.93 1.33 2.02 2.81 3.44 2.76 1.39-.06 1.91-.88 3.59-.88s2.15.88 3.6.85c1.49-.02 2.44-1.34 3.34-2.68a11.05 11.05 0 001.51-3.1 4.78 4.78 0 01-2.96-4.39z"/>
      <path d="M22.04 12.21a4.87 4.87 0 001.12-3.5 4.96 4.96 0 00-3.21 1.66 4.64 4.64 0 00-1.14 3.37 4.1 4.1 0 003.23-1.53z"/>
    </g>
    <g fill="#fff" font-family="-apple-system, SF Pro Display, system-ui, sans-serif">
      <text x="37" y="15.5" font-size="6" letter-spacing="0.02em">Download on the</text>
      <text x="37" y="29" font-size="11" font-weight="600">App Store</text>
    </g>
  </svg>
</a>
