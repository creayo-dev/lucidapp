---
import '../styles/global.css';
import { site } from '../data/config';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = site.description,
  ogImage = '/og-image.png',
  ogType = 'website',
  canonicalUrl,
  jsonLd,
} = Astro.props;

const pageTitle = title === site.name
  ? `${site.name} — ${site.tagline}`
  : `${title} | ${site.name}`;
const canonical = canonicalUrl || Astro.url.href;

const orgLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      'name': site.company,
      'url': site.url,
      'logo': `${site.url}/icon-512.png`,
      'description': site.description,
      'brand': { '@type': 'Brand', 'name': site.name },
      'contactPoint': {
        '@type': 'ContactPoint',
        'email': site.supportEmail,
        'contactType': 'customer support',
      },
    },
    {
      '@type': 'WebSite',
      'name': site.name,
      'url': site.url,
      'description': site.description,
    },
  ],
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <style is:inline>html{background:#0A0A0A}body{opacity:0}body.ready{opacity:1;transition:opacity 0.2s ease}</style>

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, site.url).href} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site.url).href} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0A0A0A" />

    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <Analytics />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
    <script is:inline>document.body.classList.add('ready')</script>
  </body>
</html>
